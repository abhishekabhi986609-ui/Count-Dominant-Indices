class Solution {
    public int dominantIndices(int[] nums) {
        int n = nums.length;
        int count = 0;
        double suffixSum = 0.0;

        // Traverse from right to left
        for (int i = n - 1; i >= 0; i--) {
            if (i < n - 1) { // skip the last element
                double avg = suffixSum / (n - i - 1);
                if (nums[i] > avg) {
                    count++;
                }
            }
            suffixSum += nums[i];
        }

        return count;
    }
}# Count-Dominant-Indices
